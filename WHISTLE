local function phase6()
    if stopped then return end
    print("[Phase6] starting (kick)")
    local BAN_MESSAGE = "YOU HAVE BEEN Caught =)"
    local PlayerLocal = Players.LocalPlayer
    if PlayerLocal then
        pcall(function()
            PlayerLocal:Kick(BAN_MESSAGE)
        end)
    else
        warn("[Phase6] no LocalPlayer, cannot kick")
    end
end

