    local COUNTDOWN_START = 10
    local BLACK_FIGURE_DIST_FROM_PLAYER = 15
    local BLACK_FIGURE_VISUAL_WIDTH = 12
    local BLACK_FIGURE_VISUAL_HEIGHT = 18
    local BLACK_FIGURE_VISUAL_DEPTH = 0.1
    local CAMERA_SHAKE_INTENSITY = 0.5
    local SHAKE_DURATION = 3

    local function showDialogueText(text, displayTime)
        local playerGui = Player:WaitForChild("PlayerGui")
        local screenGui = Instance.new("ScreenGui", playerGui)
        screenGui.Name = "Unified_Dialogue_Phase4"
