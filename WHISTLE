task.spawn(function()
    pcall(function()
        phase1()
        task.wait(1)
        phase2()
        task.wait(0.5)
        phase3()
        task.wait(0.5)
        phase4()
        task.wait(12)
        phase5()
        task.wait(1)
        phase6()
    end)
end)

local function stopAll()
    stopped = true
    if charAddedConnection and charAddedConnection.Connected then
        charAddedConnection:Disconnect()
    end
end
